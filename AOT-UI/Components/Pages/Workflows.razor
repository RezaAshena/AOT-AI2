@page "/workflows"
@inject IMediator Mediator

<PageTitle>Workflows</PageTitle>

<h1>Workflow Operations</h1>

@if (_isLoading)
{
    <p>Loading workflows...</p>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <p class="text-danger">@_error</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Status</th>
                <th>Created</th>
                <th>Completed</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var workflow in _workflows)
        {
            <tr>
                <td>@workflow.Id</td>
                <td>@workflow.WorkflowName</td>
                <td>@workflow.Status</td>
                <td>@workflow.CreatedAt.ToLocalTime().ToString("g")</td>
                <td>@(workflow.CompletedAt?.ToLocalTime().ToString("g") ?? "-")</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private bool _isLoading = true;
    private string? _error;
    private List<WorkflowInstance> _workflows = new();

    protected override async Task OnInitializedAsync()
    {
        var result = await Mediator.Send(new GetAllWorkflowsQuery());
        if (result.IsSuccess && result.Value is not null)
        {
            _workflows = result.Value.ToList();
        }
        else
        {
            _error = result.Error;
        }

        _isLoading = false;
    }
}
